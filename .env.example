# Binance USD-M futures (hedge mode)
bn_api_key=your_api_key
bn_api_secret=your_api_secret

# --- 實盤執行 ---
FIBB_DRY_RUN=1
FIBB_ENABLE_HEDGE_MODE=1
FIBB_SYMBOL=BTCUSDT
FIBB_INTERVAL=15m

# --- 策略參數（回測與實盤共用，未設則用 fibb_config.py 預設）---
FIBB_LENGTH=20
FIBB_TP_PCT=0.5
FIBB_SL_PCT=0.5
FIBB_FIB_RATIO_1=1.618
FIBB_FIB_RATIO_2=2.618
FIBB_FIB_RATIO_3=4.236
FIBB_FEE_RATE=0.0004
FIBB_MAX_OPEN_LEGS=6
# 允許開倉方向：both（多空）| long（只做多）| short（只做空）
FIBB_TRADE_SIDES=both
FIBB_INITIAL_CAPITAL=100000
FIBB_LEVERAGE=150
FIBB_DEFERRED_SL=1
# 持倉逾時強平（小時）；0=關閉。逾時以當根收盤價記帳，實盤平倉走 pre-limit → IOC → market
FIBB_MAX_HOLDING_HOURS=30
# 4H 波動分檔：高波動時保守（縮 TP、縮短 max hold、限制外層逆勢 T3/B3）
FIBB_REGIME_ENABLED=1
FIBB_REGIME_H4_LOOKBACK=60
FIBB_REGIME_H4_HIGH_VOL_QUANTILE=0.7
FIBB_REGIME_HIGH_VOL_TP_MULT=0.65
FIBB_REGIME_HIGH_VOL_MAX_HOLDING_HOURS=18
FIBB_REGIME_BLOCK_OUTER_COUNTERTREND=1

# 止盈：0=固定 %；1=每根 K 跟 basis；2=通道隨 K 漂移；3=通道開倉鎖定（價不跟 K）
FIBB_TP_MODE=0
# tp_mode 2/3：進場帶向中線偏移格數（2 → B3 止盈在 B1；1 → B3 止盈在 B2）
FIBB_CHANNEL_TP_OFFSET=2
# 舊版（未設 FIBB_TP_MODE 時仍有效）：FIBB_REPRICE_TP_TO_BASIS=1、FIBB_CHANNEL_TP=1

# Leg 下單量（BTC）：T1/B1、T2/B2、T3/B3
FIBB_QTY_T1=0.01
FIBB_QTY_T2=0.02
FIBB_QTY_T3=0.03

# --- Log ---
# FIBB_LOG_JSON=1
# FIBB_PRINT_JSON=0

# --- Realtime trader (trade/fibb_realtime_trader.py) ---
# Long-running WebSocket; do NOT run with 15m cron on same account.
# FIBB_RT_DRY_RUN=0
# FIBB_RT_USE_WS=1
# FIBB_RT_POLL_SEC=2
# FIBB_RT_KLINE_REFRESH_SEC=120
# FIBB_RT_RUNTIME_DIR=trade/runtime_realtime

# Shared trade lock (15m cron + realtime must not run together on same account)
# FIBB_TRADE_LOCK=trade/runtime/fibb_trade.lock
# FIBB_LEG_OPEN_GRACE_SEC=90
